# Site URL
NEXT_PUBLIC_SITE_URL=https://crm.relaxiospa.in

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# WhatsApp Encryption
ENCRYPTION_KEY=64_character_hex_key

# Meta Webhook
META_APP_SECRET=your_meta_app_secret
META_VERIFY_TOKEN=change_this_to_random_string

# Automation Cron Security
AUTOMATION_CRON_SECRET=change_this_to_random_secret

# Invite Link Security
ALLOWED_INVITE_HOSTS=crm.relaxiospa.in

# WhatsApp Template Testing
WHATSAPP_TEMPLATES_DRY_RUN=false